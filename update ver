<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script>
const lenis=new Lenis({duration:1.1,easing:t=>Math.min(1,1.001-Math.pow(2,-10*t)),smooth:true});
function raf(t){lenis.raf(t);requestAnimationFrame(raf);} requestAnimationFrame(raf);
gsap.registerPlugin(ScrollTrigger);
lenis.on('scroll',ScrollTrigger.update);
gsap.ticker.add(t=>lenis.raf(t*1000));
gsap.ticker.lagSmoothing(0);
gsap.to('.card-1',{y:-16,rotation:-.8,duration:6,ease:'sine.inOut',repeat:-1,yoyo:true});
gsap.to('.card-2',{y:-11,rotation:.9,duration:7.5,ease:'sine.inOut',repeat:-1,yoyo:true,delay:.7});
gsap.to('.card-3',{y:-18,rotation:-.6,duration:5.5,ease:'sine.inOut',repeat:-1,yoyo:true,delay:1.3});
gsap.to('.card-4',{y:-13,rotation:1,duration:8,ease:'sine.inOut',repeat:-1,yoyo:true,delay:.4});
gsap.timeline({defaults:{ease:'power3.out'}})
  .from('.hero-eyebrow',{opacity:0,y:16,duration:.75},0.1)
  .from('.hero-h1',{opacity:0,y:28,duration:.85},0.25)
  .from('.hero-sub',{opacity:0,y:16,duration:.7},0.45)
  .from('.hero-tags',{opacity:0,y:12,duration:.6},0.6)
  .from('.hero-cta',{opacity:0,y:12,duration:.6},0.72)
  .from('.card-1',{opacity:0,x:-40,rotation:-5,duration:.9,ease:'power2.out'},0.2)
  .from('.card-2',{opacity:0,x:40,rotation:5,duration:.9,ease:'power2.out'},0.36)
  .from('.card-3',{opacity:0,x:-30,rotation:-4,duration:.9,ease:'power2.out'},0.5)
  .from('.card-4',{opacity:0,x:30,rotation:4,duration:.9,ease:'power2.out'},0.56);
const sel='.stag,.h2,.h2-kr,.body-text,.prob-card,.sol-step,.arch-layer,.prod-card,.tech-box,.stat-box,.mt-row,.phase-card,.rm-card,.team-card,.val-box,.vp,.contact-h,.insight-box,.full-quote,.founder-quote-big,.patent-table tr';
document.querySelectorAll(sel).forEach((el,i)=>{
  gsap.from(el,{opacity:0,y:26,duration:.78,ease:'power3.out',scrollTrigger:{trigger:el,start:'top 89%',toggleActions:'play none none none'},delay:(i%4)*.038});
});
gsap.to('.showcase-img',{scale:1.025,ease:'none',scrollTrigger:{trigger:'.showcase-wrap',start:'top bottom',end:'bottom top',scrub:2}});
gsap.to('.vision-glow',{y:-50,ease:'none',scrollTrigger:{trigger:'.vision',start:'top bottom',end:'bottom top',scrub:1.5}});
let lastY=0;const nav=document.getElementById('nav');
ScrollTrigger.create({onUpdate:s=>{const y=s.scroll();if(y>lastY&&y>80)gsap.to(nav,{y:-70,duration:.3,ease:'power2.in'});else gsap.to(nav,{y:0,duration:.3,ease:'power2.out'});lastY=y;}});
const cur=document.getElementById('cursor'),ring=document.getElementById('cursorRing');
let mx=0,my=0,rx=0,ry=0;
document.addEventListener('mousemove',e=>{mx=e.clientX;my=e.clientY;});
(function a(){cur.style.left=mx+'px';cur.style.top=my+'px';rx+=(mx-rx)*.1;ry+=(my-ry)*.1;ring.style.left=rx+'px';ring.style.top=ry+'px';requestAnimationFrame(a);})();
document.querySelectorAll('a,button,.card,.prob-card,.sol-step,.arch-layer,.prod-card,.tech-box,.stat-box,.mt-row,.phase-card,.rm-card,.team-card,.ctag,.nav-cta').forEach(el=>{
  el.addEventListener('mouseenter',()=>{cur.classList.add('h');ring.classList.add('h');});
  el.addEventListener('mouseleave',()=>{cur.classList.remove('h');ring.classList.remove('h');});
});
</script>
