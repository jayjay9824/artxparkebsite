<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8""UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>ArtXpark — 물리 자산 데이터 인프라 구축</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,300&family=Noto+Serif+KR:wght@300;400;500;600&family=Noto+Sans+KR:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/lenis@1.1.9/dist/lenis.css">
<style>
:root{
  --bg:#070707;--surface:#0f0f0e;--surface2:#181815;--surface3:#222220;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#f0ebe3;--muted:#7d7870;--muted2:#524f4b;
  --gold:#d4b47a;--gold2:#b8963f;--gold-dim:rgba(212,180,122,0.13);
  --green:#4dda7e;--white:#fff;
  --font-display:'Cormorant Garamond',serif, 'Pretendard', 'Noto Sans KR', sans-serif;
  --font-ui:'DM Sans',sans-serif, 'Pretendard', 'Noto Sans KR', sans-serif;
  --font-kr:'Noto Serif KR',serif, 'Pretendard', 'Noto Sans KR', sans-serif;
  --font-kr-sans:'Noto Sans KR',sans-serif, 'Pretendard', 'Noto Sans KR', sans-serif;
}
*{margin:0;padding:0;box-sizing:border-box;}
html.lenis,html.lenis body{height:auto;}
.lenis.lenis-smooth{scroll-behavior:auto!important;}
body{background:var(--bg);color:var(--text);font-family:var(--font-kr-sans);font-weight:300;cursor:none;overflow-x:hidden;-webkit-font-smoothing:antialiased;}

/* ── CURSOR ── */
.cursor{width:5px;height:5px;background:var(--gold);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9999;transform:translate(-50%,-50%);transition:width .3s cubic-bezier(.16,1,.3,1),height .3s cubic-bezier(.16,1,.3,1),background .3s;mix-blend-mode:exclusion;}
.cursor-ring{width:32px;height:32px;border:1px solid rgba(212,180,122,.22);border-radius:50%;position:fixed;top:0;left:0;pointer-events:none;z-index:9998;transform:translate(-50%,-50%);transition:width .35s cubic-bezier(.16,1,.3,1),height .35s cubic-bezier(.16,1,.3,1),border-color .3s;}
.cursor.h{width:12px;height:12px;background:var(--white);}
.cursor-ring.h{width:48px;height:48px;border-color:rgba(255,255,255,.35);}

/* ── NAV ── */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:0 52px;height:60px;background:rgba(7,7,7,.78);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-bottom:1px solid var(--border);transition:transform .4s ease;}
.nav-logo img{height:22px;filter:invert(1);opacity:.82;transition:opacity .2s;}
.nav-logo img:hover{opacity:1;}
.nav-links{display:flex;gap:36px;list-style:none;}
.nav-links a{font-size:11px;font-family:var(--font-ui);font-weight:500;text-transform:uppercase;color:var(--muted);text-decoration:none;letter-spacing:.09em;transition:color .25s;}
.nav-links a:hover{color:var(--text);}
.nav-cta{font-family:var(--font-ui);font-size:11px;font-weight:600;letter-spacing:.08em;padding:8px 22px;border:1px solid var(--gold);background:transparent;color:var(--gold);border-radius:40px;cursor:none;transition:background .25s,color .25s,transform .2s;}
.nav-cta:hover{background:var(--gold);color:var(--bg);transform:translateY(-1px);}

/* ── HERO ── */
.hero{min-height:100vh;padding:60px 0 0;position:relative;overflow:hidden;display:flex;flex-direction:column;}
.canvas{position:relative;flex:1;min-height:calc(100vh - 60px);}
.canvas::before{content:'';position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.022'/%3E%3C/svg%3E");pointer-events:none;z-index:0;}
.canvas-glow{position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 48% 52% at 50% 50%,rgba(212,180,122,.038) 0%,transparent 65%);}
.hero-svg{position:absolute;inset:0;width:100%;height:100%;pointer-events:none;z-index:1;}

/* HERO TEXT */
.hero-center{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);text-align:center;z-index:2;pointer-events:none;width:100%;padding:0 40px;}
.hero-eyebrow{font-size:10px;letter-spacing:.42em;color:var(--gold);text-transform:uppercase;margin-bottom:12px;font-family:var(--font-ui);font-weight:500;opacity:.85;}
.hero-h1{font-family:var(--font-display);font-size:clamp(20px,2.2vw,30px);font-weight:400;line-height:1.1;letter-spacing:-.015em;color:var(--white);white-space:nowrap;}
.hero-h1 em{font-style:normal;color:var(--gold);}
.hero-sub{margin-top:14px;font-size:12px;font-weight:300;color:rgba(240,235,227,.62);letter-spacing:.015em;line-height:1.8;max-width:480px;margin-left:auto;margin-right:auto;font-family:var(--font-kr-sans);}
.hero-tags{margin-top:14px;display:flex;gap:8px;justify-content:center;flex-wrap:wrap;}
.hero-tag{font-family:var(--font-ui);font-size:9px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;padding:5px 12px;border:1px solid rgba(212,180,122,.22);color:rgba(212,180,122,.55);border-radius:20px;}
.hero-logo-wrap{margin-bottom:20px;display:flex;justify-content:center;align-items:center;}
.hero-logo-img{height:40px;filter:invert(1);opacity:.92;display:block;max-width:200px;}
.hero-cta{margin-top:24px;display:flex;gap:12px;justify-content:center;pointer-events:all;}
.btn-gold{font-family:var(--font-ui);font-size:11px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;padding:12px 28px;border-radius:40px;cursor:none;text-decoration:none;background:var(--gold);color:var(--bg);border:none;box-shadow:0 8px 24px rgba(212,180,122,.2);transition:opacity .3s,transform .2s,box-shadow .3s;}
.btn-gold:hover{opacity:.88;transform:translateY(-2px);box-shadow:0 12px 30px rgba(212,180,122,.3);}
.btn-line{font-family:var(--font-ui);font-size:11px;font-weight:600;letter-spacing:.09em;text-transform:uppercase;padding:12px 28px;border-radius:40px;cursor:none;text-decoration:none;background:transparent;color:var(--text);border:1px solid rgba(255,255,255,.1);transition:border-color .25s,color .25s,transform .2s;}
.btn-line:hover{border-color:var(--gold);color:var(--gold);transform:translateY(-2px);}

/* CARDS */
.card{position:absolute;background:rgba(12,12,11,.93);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border:1px solid var(--border);border-radius:14px;overflow:hidden;box-shadow:0 20px 50px rgba(0,0,0,.6),0 0 0 1px rgba(255,255,255,.025);z-index:3;}
.card-hd{padding:10px 14px;font-family:var(--font-ui);font-size:9px;font-weight:500;color:var(--muted);letter-spacing:.16em;text-transform:uppercase;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;}
.card-hd span:last-child{color:var(--gold);}
.card img{width:100%;display:block;object-fit:cover;}
.card-body{position:relative;overflow:hidden;background:var(--surface2);}
.cpill{position:absolute;bottom:9px;left:9px;background:rgba(0,0,0,.8);backdrop-filter:blur(6px);border:1px solid rgba(255,255,255,.07);border-radius:20px;padding:4px 10px;font-size:9px;color:var(--muted);font-family:var(--font-ui);letter-spacing:.08em;text-transform:uppercase;}
.cviz{padding:16px 14px;display:flex;flex-direction:column;gap:9px;}
.vrow{display:flex;align-items:center;gap:10px;}
.vlabel{font-size:9px;color:var(--muted);width:48px;font-family:var(--font-ui);text-transform:uppercase;letter-spacing:.06em;font-weight:500;}
.vbw{flex:1;height:3px;background:rgba(255,255,255,.05);border-radius:2px;overflow:hidden;}
.vb{height:100%;background:var(--gold);border-radius:2px;}
.vval{font-size:9px;color:var(--gold);font-family:var(--font-ui);width:34px;text-align:right;font-weight:600;}
.vgreen{color:var(--green)!important;background:var(--green)!important;}
.vtitle{font-family:var(--font-ui);font-size:9px;font-weight:600;color:var(--muted);letter-spacing:.16em;margin-bottom:8px;border-bottom:1px solid var(--border);padding-bottom:6px;text-transform:uppercase;}
.vlist{display:flex;flex-direction:column;gap:6px;}
.vli{display:flex;justify-content:space-between;font-size:10px;font-family:var(--font-ui);}
.vli span:first-child{color:var(--muted);}
.vli .vgold{color:var(--gold);font-weight:500;}
.vli .vgreen2{color:var(--green);font-weight:600;}
.live{display:flex;align-items:center;gap:5px;color:var(--green);font-family:var(--font-ui);font-size:9px;letter-spacing:.1em;font-weight:500;}
.live::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--green);animation:pulse 2s infinite;flex-shrink:0;}
.card-1{width:228px;top:10%;left:5%;}
.card-2{width:272px;top:8%;right:6%;}
.card-3{width:248px;bottom:13%;left:7%;}
.card-4{width:290px;bottom:7%;right:5%;}

/* MARQUEE */
.marquee{border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:16px 0;overflow:hidden;background:rgba(0,0,0,.4);}
.mtrack{display:flex;gap:64px;white-space:nowrap;animation:mq 30s linear infinite;width:max-content;}
.mitem{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:64px;}
.mitem::after{content:'✦';color:var(--gold);font-size:8px;opacity:.55;}
@keyframes mq{from{transform:translateX(0)}to{transform:translateX(-50%)}}

/* ── SECTIONS ── */
.sec{padding:140px 80px;border-top:1px solid var(--border);position:relative;}
.stag{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.42em;text-transform:uppercase;color:var(--gold);margin-bottom:52px;display:inline-block;padding-bottom:7px;border-bottom:1px solid var(--gold-dim);}
.h2{font-family:var(--font-display);font-size:clamp(28px,3.2vw,52px);font-weight:400;line-height:1.04;letter-spacing:-.01em;color:var(--white);word-break:keep-all;}
.h2 em{font-style:normal;color:var(--gold);}
.h2-kr{font-family:var(--font-kr);font-size:clamp(24px,2.8vw,46px);font-weight:300;line-height:1.15;letter-spacing:-.01em;color:var(--white);word-break:keep-all;}
.h2-kr em{font-style:normal;color:var(--gold);font-weight:400;}
.body-text{font-size:15px;color:var(--muted);line-height:1.92;font-weight:300;font-family:var(--font-kr-sans);}
.body-sm{font-size:13px;color:var(--muted);line-height:1.88;font-family:var(--font-kr-sans);}
.gold-text{color:var(--gold);}
.quote-bar{border-left:2px solid var(--gold);padding-left:24px;font-family:var(--font-kr);font-size:clamp(16px,1.8vw,24px);font-weight:300;color:var(--text);line-height:1.55;word-break:keep-all;}
.full-quote{background:var(--surface2);border-left:2px solid var(--gold);padding:24px 32px;margin-top:36px;font-family:var(--font-kr);font-size:clamp(14px,1.4vw,20px);font-weight:300;color:var(--text);line-height:1.62;word-break:keep-all;}
.insight-box{background:var(--surface2);border:1px solid rgba(212,180,122,.14);padding:22px 30px;margin-top:28px;}
.insight-label{font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);margin-bottom:7px;}
.insight-text{font-size:13px;color:var(--muted);line-height:1.85;font-family:var(--font-kr-sans);}
.insight-text strong{color:var(--text);font-weight:400;}

/* GRIDS */
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.two-col-gap{display:grid;grid-template-columns:1fr 1fr;gap:80px;align-items:start;}
.three-col{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);}
.four-col{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);}
.five-step{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);border:1px solid var(--border);}
.col-l{padding-right:80px;border-right:1px solid var(--border);}
.col-r{padding-left:80px;}

/* PROBLEM */
.prob-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:48px;}
.prob-card{background:var(--bg);padding:40px 28px;position:relative;transition:background .3s;}
.prob-card:hover{background:var(--surface);}
.prob-icon{font-size:22px;margin-bottom:16px;}
.prob-title{font-family:var(--font-ui);font-size:14px;font-weight:600;color:var(--white);margin-bottom:12px;letter-spacing:-.01em;}
.prob-body{font-size:12px;color:var(--muted);line-height:1.78;font-family:var(--font-kr-sans);}

/* SOLUTION STEPS */
.sol-step{background:var(--bg);padding:36px 28px;position:relative;transition:background .3s;}
.sol-step:hover{background:var(--surface);}
.step-num{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.2em;color:var(--gold);margin-bottom:16px;}
.step-title{font-family:var(--font-ui);font-size:15px;font-weight:600;color:var(--white);margin-bottom:10px;}
.step-body{font-size:12px;color:var(--muted);line-height:1.78;font-family:var(--font-kr-sans);}

/* ARCHITECTURE */
.arch-wrap{display:flex;flex-direction:column;gap:1px;border:1px solid var(--border);background:var(--border);}
.arch-layer{background:var(--bg);display:grid;grid-template-columns:220px 1fr auto;align-items:center;padding:26px 36px;gap:40px;transition:background .3s,padding-left .3s;}
.arch-layer:hover{background:var(--surface);padding-left:48px;}
.layer-num{font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.2em;color:var(--muted2);text-transform:uppercase;display:block;margin-bottom:4px;}
.layer-name{font-family:var(--font-ui);font-size:20px;font-weight:700;color:var(--white);letter-spacing:-.01em;}
.layer-name .ax{color:var(--gold);}
.layer-items{display:flex;gap:20px;flex-wrap:wrap;}
.layer-chip{font-size:11px;color:var(--muted);font-family:var(--font-ui);letter-spacing:.04em;display:flex;align-items:center;gap:6px;}
.layer-chip::before{content:'·';color:var(--gold);}
.layer-desc{font-size:11px;color:var(--muted2);text-align:right;font-family:var(--font-ui);letter-spacing:.05em;white-space:nowrap;}

/* PRODUCTS */
.prod-card{background:var(--bg);padding:52px 40px;position:relative;overflow:hidden;transition:background .4s;}
.prod-card:hover{background:var(--surface);}
.prod-bg-txt{position:absolute;bottom:-20px;right:-10px;font-family:var(--font-display);font-size:160px;color:rgba(255,255,255,.012);line-height:1;pointer-events:none;font-style:normal;transition:color .4s,transform .4s;}
.prod-card:hover .prod-bg-txt{color:rgba(212,180,122,.04);transform:scale(1.04);}
.prod-tag{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);margin-bottom:18px;display:flex;align-items:center;gap:10px;}
.prod-tag::before{content:'';width:18px;height:1px;background:var(--gold);}
.prod-name{font-family:var(--font-ui);font-size:36px;font-weight:700;color:var(--white);margin-bottom:12px;letter-spacing:-.02em;}
.prod-name .ax{color:var(--gold);}
.prod-desc{font-size:13px;color:var(--muted);line-height:1.82;margin-bottom:28px;font-family:var(--font-kr-sans);}
.prod-caps{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:28px;}
.prod-caps li{font-size:12px;color:rgba(240,235,227,.55);display:flex;align-items:flex-start;gap:8px;line-height:1.65;font-family:var(--font-kr-sans);}
.prod-caps li::before{content:'—';color:var(--gold);flex-shrink:0;}
.prod-img{width:100%;border-radius:8px;overflow:hidden;border:1px solid var(--border);}
.prod-img img{width:100%;display:block;object-fit:cover;filter:brightness(.88) contrast(1.05);transition:transform .6s ease;}
.prod-img:hover img{transform:scale(1.03);}

/* TECH STACK */
.tech-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1px;background:var(--border);border:1px solid var(--border);}
.tech-box{background:var(--bg);padding:44px 36px;position:relative;overflow:hidden;transition:background .3s;}
.tech-box:hover{background:var(--surface);}
.tech-badge{display:inline-block;font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;padding:4px 10px;border:1px solid rgba(212,180,122,.28);color:var(--gold);border-radius:20px;margin-bottom:20px;}
.tech-title{font-family:var(--font-ui);font-size:20px;font-weight:700;color:var(--white);margin-bottom:6px;letter-spacing:-.01em;}
.tech-sub-label{font-size:11px;color:var(--gold);font-family:var(--font-ui);letter-spacing:.05em;margin-bottom:14px;font-weight:500;}
.tech-body{font-size:13px;color:var(--muted);line-height:1.82;margin-bottom:16px;font-family:var(--font-kr-sans);}
.tech-result{font-family:var(--font-ui);font-size:11px;font-weight:600;color:var(--text);letter-spacing:.04em;}
.tech-result::before{content:'결과: ';color:var(--gold);}

/* PATENT TABLE */
.patent-table{width:100%;border-collapse:collapse;margin-top:40px;}
.patent-table th{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);padding:14px 20px;text-align:left;border-bottom:1px solid var(--border);}
.patent-table td{font-size:13px;color:var(--muted);padding:20px 20px;border-bottom:1px solid var(--border);line-height:1.65;vertical-align:middle;font-family:var(--font-kr-sans);}
.patent-table tr:hover td{color:var(--text);background:rgba(255,255,255,.012);}
.patent-table td:first-child{font-family:var(--font-ui);font-size:11px;color:var(--muted2);font-weight:400;}
.patent-badge{display:inline-block;font-family:var(--font-ui);font-size:9px;letter-spacing:.1em;text-transform:uppercase;padding:3px 8px;border:1px solid rgba(212,180,122,.24);color:var(--gold);border-radius:10px;white-space:nowrap;}

/* MARKET */
.market-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:48px;}
.stat-box{background:var(--bg);padding:40px 32px;transition:background .3s;}
.stat-box:hover{background:var(--surface);}
.stat-num{font-family:var(--font-display);font-size:clamp(28px,3vw,46px);font-weight:400;color:var(--gold);line-height:1;margin-bottom:8px;letter-spacing:-.015em;}
.stat-label{font-family:var(--font-ui);font-size:11px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--white);margin-bottom:6px;}
.stat-note{font-size:12px;color:var(--muted);line-height:1.65;font-family:var(--font-kr-sans);}
.market-targets{display:flex;flex-direction:column;gap:1px;background:var(--border);border:1px solid var(--border);margin-top:20px;}
.mt-row{background:var(--bg);display:grid;grid-template-columns:1fr auto;align-items:center;padding:20px 28px;gap:20px;transition:background .3s,padding-left .3s;}
.mt-row:hover{background:var(--surface);padding-left:40px;}
.mt-row.highlight{background:rgba(212,180,122,.055);border-left:2px solid var(--gold);}
.mt-name{font-size:14px;color:var(--text);font-family:var(--font-kr-sans);}
.mt-val{font-family:var(--font-ui);font-size:13px;font-weight:600;color:var(--gold);text-align:right;}

/* GTM */
.phase-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:48px;}
.phase-card{background:var(--bg);padding:40px 28px;position:relative;transition:background .3s;}
.phase-card:hover{background:var(--surface);}
.phase-card.active{background:var(--surface2);}
.phase-num{font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:12px;}
.phase-title{font-family:var(--font-ui);font-size:17px;font-weight:700;color:var(--white);margin-bottom:16px;line-height:1.2;}
.phase-product{font-size:10px;color:var(--muted2);font-family:var(--font-ui);letter-spacing:.06em;text-transform:uppercase;margin-bottom:8px;font-weight:500;}
.phase-body{font-size:12px;color:var(--muted);line-height:1.72;margin-bottom:12px;font-family:var(--font-kr-sans);}
.phase-output{font-size:11px;color:var(--gold);line-height:1.62;font-family:var(--font-kr-sans);}

/* ROADMAP */
.roadmap-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:48px;}
.rm-card{background:var(--bg);padding:40px 28px;transition:background .3s;}
.rm-card.current{background:var(--surface2);border-top:2px solid var(--gold);}
.rm-card:hover{background:var(--surface);}
.rm-year{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.16em;color:var(--muted2);margin-bottom:8px;}
.rm-phase{font-family:var(--font-ui);font-size:14px;font-weight:700;color:var(--gold);margin-bottom:16px;letter-spacing:-.005em;}
.rm-items{display:flex;flex-direction:column;gap:8px;}
.rm-item{font-size:12px;color:var(--muted);line-height:1.65;display:flex;align-items:flex-start;gap:8px;font-family:var(--font-kr-sans);}
.rm-dot{width:5px;height:5px;border-radius:50%;background:var(--gold);flex-shrink:0;margin-top:5px;opacity:.55;}
.rm-dot.done{background:var(--green);opacity:1;}

/* TEAM */
.founder-hero{display:grid;grid-template-columns:1fr 1fr;gap:0;margin-top:40px;border:1px solid var(--border);}
.founder-left{padding:52px;border-right:1px solid var(--border);}
.founder-right{padding:52px;background:var(--surface2);}
.founder-section-title{font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;}
.founder-quote-big{font-family:var(--font-display);font-size:clamp(22px,2.5vw,36px);font-style:normal;color:var(--white);line-height:1.3;border-left:2px solid var(--gold);padding-left:24px;word-break:keep-all;margin-bottom:32px;}
.founder-name-big{font-family:var(--font-kr);font-size:28px;font-weight:400;color:var(--white);margin-bottom:4px;}
.founder-title-txt{font-family:var(--font-ui);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:28px;}
.founder-exp-title{font-family:var(--font-ui);font-size:9px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;color:var(--muted2);margin-bottom:10px;margin-top:20px;}
.founder-exp-items{display:flex;flex-direction:column;gap:6px;}
.founder-exp-item{font-size:12px;color:var(--muted);display:flex;align-items:flex-start;gap:8px;font-family:var(--font-kr-sans);}
.founder-exp-item strong{color:var(--text);font-weight:400;}
.team-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);border:1px solid var(--border);margin-top:40px;}
.team-card{background:var(--bg);padding:44px;transition:background .3s;}
.team-card:hover{background:var(--surface);}
.team-name{font-family:var(--font-kr);font-size:20px;font-weight:400;color:var(--white);margin-bottom:4px;}
.team-role{font-family:var(--font-ui);font-size:11px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--gold);margin-bottom:20px;}
.team-items{display:flex;flex-direction:column;gap:6px;}
.team-item{font-size:12px;color:var(--muted);display:flex;align-items:flex-start;gap:8px;line-height:1.65;font-family:var(--font-kr-sans);}
.team-item::before{content:'·';color:var(--gold);flex-shrink:0;}

/* VISION */
.vision{min-height:60vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:120px 80px;position:relative;overflow:hidden;border-top:1px solid var(--border);}
.vision-glow{position:absolute;width:70vw;height:70vw;max-width:900px;max-height:900px;background:radial-gradient(circle,rgba(212,180,122,.046) 0%,transparent 68%);top:50%;left:50%;transform:translate(-50%,-50%);pointer-events:none;}
.vision-h{font-family:var(--font-display);font-size:clamp(36px,4.8vw,72px);font-weight:400;line-height:.95;letter-spacing:-.02em;color:var(--white);max-width:820px;margin-bottom:40px;position:relative;z-index:2;}
.vision-h em{font-style:normal;color:var(--gold);}
.vision-points{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:52px;width:100%;max-width:860px;position:relative;z-index:2;}
.vp{background:var(--bg);padding:32px 28px;text-align:left;}
.vp-num{font-family:var(--font-display);font-size:28px;font-weight:400;color:rgba(212,180,122,.2);margin-bottom:12px;font-style:normal;}
.vp-text{font-size:13px;color:var(--muted);line-height:1.78;font-family:var(--font-kr-sans);}

/* CONTACT */
.contact-wrap{display:grid;grid-template-columns:1fr 1fr;gap:100px;}
.contact-h{font-family:var(--font-display);font-size:clamp(28px,3vw,50px);font-weight:400;line-height:1.05;letter-spacing:-.01em;margin:0 0 32px;}
.contact-h em{font-style:normal;color:var(--gold);}
.ctags{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:32px;}
.ctag{font-family:var(--font-ui);font-size:10px;font-weight:500;letter-spacing:.12em;text-transform:uppercase;padding:7px 15px;border:1px solid var(--border);color:var(--muted);border-radius:40px;transition:border-color .25s,color .25s;}
.ctag:hover{border-color:var(--gold);color:var(--text);}
.contact-addr{font-family:var(--font-ui);color:var(--muted);font-size:12px;line-height:1.92;margin-top:24px;}
.contact-addr strong{color:var(--gold);font-size:12px;text-transform:uppercase;letter-spacing:.1em;display:block;margin-bottom:6px;}
.form{display:flex;flex-direction:column;}
.ff{display:flex;flex-direction:column;border-bottom:1px solid var(--border);padding:20px 0;transition:border-color .25s;}
.ff:focus-within{border-color:var(--gold);}
.ff label{font-family:var(--font-ui);font-size:10px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);margin-bottom:10px;}
.ff input,.ff textarea{background:transparent;border:none;outline:none;color:var(--text);font-family:var(--font-kr-sans);font-size:14px;font-weight:300;resize:none;width:100%;}
.ff input::placeholder,.ff textarea::placeholder{color:rgba(125,120,112,.32);}
.fsub{margin-top:36px;font-family:var(--font-ui);font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;padding:16px 40px;background:var(--gold);color:var(--bg);border:none;border-radius:40px;cursor:none;align-self:flex-start;transition:transform .3s,box-shadow .3s;}
.fsub:hover{transform:translateY(-3px);box-shadow:0 14px 28px rgba(212,180,122,.22);}

/* SHOWCASE */
.showcase-wrap{padding:72px 80px 0;}
.showcase-img{width:100%;aspect-ratio:16/7;border-radius:12px;overflow:hidden;border:1px solid var(--border);}
.showcase-img img{width:100%;height:100%;object-fit:cover;display:block;filter:brightness(.84) contrast(1.1);transition:transform 10s ease;}
.showcase-img:hover img{transform:scale(1.03);}
.showcase-cap{display:flex;justify-content:space-between;align-items:center;padding:14px 4px;border-bottom:1px solid var(--gold-dim);margin-top:16px;}
.cap-hl{font-size:10px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--gold);font-family:var(--font-ui);display:flex;align-items:center;gap:8px;}
.cap-hl::before{content:'●';color:var(--green);font-size:7px;animation:pulse 2s infinite;}
.cap-sub{font-size:10px;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;font-family:var(--font-ui);}

/* ARTENA */
.value-three{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:32px;}
.val-box{background:var(--bg);padding:28px;transition:background .3s;}
.val-box:hover{background:var(--surface);}
.val-title{font-family:var(--font-display);font-size:22px;font-style:normal;color:var(--gold);margin-bottom:8px;}
.val-sub{font-size:11px;color:var(--muted);line-height:1.72;font-family:var(--font-kr-sans);}

/* FOOTER */
footer{border-top:1px solid var(--border);padding:36px 80px;display:flex;align-items:center;justify-content:space-between;background:#000;}
.foot-logo img{height:20px;filter:invert(1);opacity:.72;}
.foot-copy{font-size:11px;color:rgba(125,120,112,.42);letter-spacing:.04em;font-family:var(--font-ui);line-height:1.82;text-align:right;}

@keyframes pulse{0%,100%{opacity:1}50%{opacity:.2}}

/* RESPONSIVE */
@media(max-width:1100px){
  .sec{padding:100px 40px;}
  .showcase-wrap{padding:60px 40px 0;}
  .two-col,.two-col-gap,.contact-wrap,.founder-hero{grid-template-columns:1fr;gap:0;}
  .col-l{padding-right:0;border-right:none;padding-bottom:40px;border-bottom:1px solid var(--border);}
  .col-r{padding-left:0;padding-top:40px;}
  .founder-left{border-right:none;border-bottom:1px solid var(--border);}
  .five-step,.tech-grid,.prob-grid{grid-template-columns:1fr;}
  .four-col,.roadmap-grid,.phase-grid{grid-template-columns:repeat(2,1fr);}
  .team-grid{grid-template-columns:1fr;}
  .vision-points{grid-template-columns:1fr;}
  footer{padding:28px 24px;flex-direction:column;gap:14px;align-items:flex-start;}
  .foot-copy{text-align:left;}
}
@media(max-width:768px){
  .nav{padding:0 20px;}
  .nav-links{display:none;}
  .sec{padding:72px 20px;}
  .showcase-wrap{padding:40px 20px 0;}
  .hero-h1{white-space:normal;font-size:clamp(42px,10vw,68px);}
  .hero-cta{flex-direction:column;align-items:center;}
  .card{display:none;}
  .arch-layer{grid-template-columns:1fr;gap:12px;}
  .market-stats,.three-col{grid-template-columns:1fr;}
  .four-col,.roadmap-grid,.phase-grid{grid-template-columns:1fr;}
}
</style>
